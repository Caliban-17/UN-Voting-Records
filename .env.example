# Data Sources
UN_DIGITAL_LIBRARY_URL=https://digitallibrary.un.org
UN_VOTING_DATA_PATH=2025_03_31_ga_voting_corr1.csv

# Performance Optimization (reduce CPU load)
# Limit dataset for faster processing (0 = no limit, use full dataset)
MAX_ROWS_TO_LOAD=0
# Reduce workers for lower CPU usage (1-4 recommended)
MAX_WORKERS=2
# Chunk size for processing (smaller = lower memory, but slower)
CHUNK_SIZE=5000

# Caching Configuration
CACHE_DIR=.cache
CACHE_TTL_HOURS=24
USE_PARQUET_CACHE=true

# Web Scraping Configuration
SCRAPING_DELAY_SECONDS=2
MAX_RETRIES=3
USER_AGENT=UN-Voting-Analyzer/1.0

# Update Schedule (cron format)
# Default: Daily at 2 AM UTC
AUTO_UPDATE_CRON=0 2 * * *
ENABLE_AUTO_UPDATE=true

# Network Analysis Configuration
DEFAULT_SIMILARITY_THRESHOLD=0.7
MIN_EDGE_WEIGHT=0.5

# Soft Power Weights (must sum to 1.0)
PAGERANK_WEIGHT=0.4
BETWEENNESS_WEIGHT=0.3
EIGENVECTOR_WEIGHT=0.2
VOTE_SWAYING_WEIGHT=0.1

# Temporal Weighting for Historical Data
# Exponential decay factor (higher = more recent bias)
TEMPORAL_DECAY_FACTOR=0.95

# Performance Settings
MAX_WORKERS=4
CHUNK_SIZE=10000

# Logging
LOG_LEVEL=INFO
LOG_FILE=output.log
